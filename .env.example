# Copy this file to .env and fill in your real values.

# API-Football key from API-SPORTS / API-Football.
API_FOOTBALL_KEY=
API_FOOTBALL_RETRIES=3

# Local web server defaults.
WORLDCUP_WEB_HOST=127.0.0.1
WORLDCUP_WEB_PORT=8765

# Local SQLite database path.
WORLDCUP_DB_PATH=storage/worldcup_predictor.sqlite3

# Shared online deployment: hide visitor API-key entry and use the server-side key only.
WORLDCUP_PUBLIC_MODE=false

# Set both values for a password-protected shared link.
WORLDCUP_ACCESS_USER=viewer
WORLDCUP_ACCESS_PASSWORD=
